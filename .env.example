# ============================================================
# PostgreSQL (destino - Next.js app)
# ============================================================
# Usar sslmode=verify-full para evitar advertencias de deprecación de pg-connection-string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/logiacaleuche?sslmode=verify-full"

# ============================================================
# MySQL (origen - datos legacy a migrar)
# ============================================================
MYSQL_HOST="localhost"
MYSQL_PORT="3306"
MYSQL_USER="root"
MYSQL_PASSWORD="root"
MYSQL_DATABASE="caleuche"

# ============================================================
# NextAuth v5 (Auth.js)
# ============================================================
NEXTAUTH_SECRET="genera-con: openssl rand -base64 32"
NEXTAUTH_URL="https://tu-dominio.cl"
AUTH_TRUST_HOST=true


# ============================================================
# Cron Jobs (Vercel Cron / llamadas externas)
# ============================================================
CRON_SECRET="genera-con: openssl rand -base64 32"
